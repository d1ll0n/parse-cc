{
  "name": "parse-cc",
  "version": "0.2.0",
  "description": "Parse Claude Code session .jsonl logs into typed entries, metrics, tool calls, subagents, and more.",
  "keywords": [
    "claude",
    "claude-code",
    "logs",
    "jsonl",
    "session",
    "parser",
    "typescript"
  ],
  "author": "d1ll0n",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/d1ll0n/parse-cc.git"
  },
  "bugs": {
    "url": "https://github.com/d1ll0n/parse-cc/issues"
  },
  "homepage": "https://github.com/d1ll0n/parse-cc#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "biome lint --error-on-warnings",
    "lint:fix": "biome lint --write --error-on-warnings",
    "lint:ci": "biome lint --error-on-warnings --reporter=github",
    "types:sync": "node --experimental-strip-types scripts/sync-types-md.ts --verbose",
    "types:check": "node --experimental-strip-types scripts/sync-types-md.ts --verbose --check",
    "audit:logs": "tsx scripts/audit-log-schema.ts",
    "audit:logs:update": "tsx scripts/audit-log-schema.ts --update-baseline",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm run types:check && npm test && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
